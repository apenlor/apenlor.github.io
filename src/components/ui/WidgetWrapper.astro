---
import type { HTMLTag } from 'astro/types';
import type { Widget } from '~/types';
import { twMerge } from 'tailwind-merge';
import Background from './Background.astro';

export interface Props extends Widget {
  containerClass?: string;
  ['as']?: HTMLTag;
}

const spacingMap = {
  normal: 'py-12 md:py-16 lg:py-20',
  compact: 'py-8 md:py-10 lg:py-12',
  tight: 'py-4 md:py-6 lg:py-8',
  none: 'py-0',
} as const;

const { id, isDark = false, containerClass = '', bg, as = 'section', spacing = 'normal' } = Astro.props;

const WrapperTag = as;
---

<WrapperTag class="relative not-prose scroll-mt-[72px]" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : <Background isDark={isDark} />}
    </slot>
  </div>
  <div
    class:list={[
      twMerge(
        `relative mx-auto max-w-7xl px-4 md:px-6 ${spacingMap[spacing]} text-default intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade`,
        containerClass
      ),
      { dark: isDark },
    ]}
  >
    <slot />
  </div>
</WrapperTag>
