---
import type { MarkdownHeading } from "astro";

export interface Props {
  headings: MarkdownHeading[];
  maxDepth?: number;
}

interface TocHeading extends MarkdownHeading {
  children: TocHeading[];
}

const { headings, maxDepth = 3 } = Astro.props;

const filteredHeadings = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= maxDepth,
);

function buildTocTree(headings: MarkdownHeading[]): TocHeading[] {
  const tree: TocHeading[] = [];
  const stack: TocHeading[] = [];

  for (const heading of headings) {
    const node: TocHeading = { ...heading, children: [] };
    while (stack.length > 0 && stack[stack.length - 1].depth >= heading.depth) {
      stack.pop();
    }
    if (stack.length === 0) {
      tree.push(node);
    } else {
      stack[stack.length - 1].children.push(node);
    }
    stack.push(node);
  }

  return tree;
}

const tocTree = buildTocTree(filteredHeadings);
---

{
  tocTree.length > 0 && (
    <nav class="toc-nav" aria-label="Table of Contents">
      <h4 class="mb-3 text-sm font-bold font-heading uppercase tracking-wider text-default dark:text-slate-300">
        Table of Contents
      </h4>
      <ul class="toc-list flex flex-col text-sm">
        {tocTree.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-1 text-muted hover:text-primary dark:text-slate-400 dark:hover:text-blue-400 transition-colors border-l-2 border-transparent pl-3"
              data-heading-slug={heading.slug}
            >
              {heading.text}
            </a>
            {heading.children.length > 0 && (
              <ul class="flex flex-col">
                {heading.children.map((child) => (
                  <li>
                    <a
                      href={`#${child.slug}`}
                      class="toc-link block py-1 text-muted hover:text-primary dark:text-slate-400 dark:hover:text-blue-400 transition-colors border-l-2 border-transparent pl-6"
                      data-heading-slug={child.slug}
                    >
                      {child.text}
                    </a>
                    {child.children.length > 0 && (
                      <ul class="flex flex-col">
                        {child.children.map((grandchild) => (
                          <li>
                            <a
                              href={`#${grandchild.slug}`}
                              class="toc-link block py-1 text-muted hover:text-primary dark:text-slate-400 dark:hover:text-blue-400 transition-colors border-l-2 border-transparent pl-9"
                              data-heading-slug={grandchild.slug}
                            >
                              {grandchild.text}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  function initTocHighlighting() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (tocLinks.length === 0) return;

    const headingSlugs = Array.from(tocLinks).map((link) => link.dataset.headingSlug!);
    const headingElements = headingSlugs
      .map((slug) => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    function setActive(slug: string) {
      tocLinks.forEach((link) => {
        if (link.dataset.headingSlug === slug) {
          link.classList.add(
            "!border-primary",
            "!text-primary",
            "dark:!text-blue-400",
            "dark:!border-blue-400",
            "font-medium",
          );
        } else {
          link.classList.remove(
            "!border-primary",
            "!text-primary",
            "dark:!text-blue-400",
            "dark:!border-blue-400",
            "font-medium",
          );
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      {
        root: null,
        rootMargin: "-80px 0px -60% 0px",
        threshold: 0,
      },
    );

    headingElements.forEach((el) => observer.observe(el));
  }

  // Run on initial load
  initTocHighlighting();

  // Re-init on Astro view transitions
  document.addEventListener("astro:after-swap", initTocHighlighting);
</script>
