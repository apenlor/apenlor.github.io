---
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import ItemGrid from "~/components/ui/ItemGrid.astro";
import Image from "~/components/common/Image.astro";
import Steps from "~/components/widgets/Steps.astro";
import Layout from "~/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "About",
  description:
    "So, who the heck is this guy? Meet Alejandro Pena Lorenzo, a Software Engineer with over a decade of experience.",
};

const socialLinks = [
  {
    icon: "tabler:brand-bluesky",
    callToAction: {
      target: "_blank",
      text: "Bluesky",
      href: "https://bsky.app/profile/apenlor.github.io",
    },
  },
  {
    icon: "tabler:brand-linkedin",
    callToAction: {
      target: "_blank",
      text: "LinkedIn",
      href: "https://www.linkedin.com/in/alejandropenalorenzo",
    },
  },
  {
    icon: "tabler:brand-github",
    callToAction: {
      target: "_blank",
      text: "GitHub",
      href: "https://github.com/apenlor",
    },
  },
];

const certifications = [
  {
    title: "Generative AI Leader",
    description: "Google",
    icon: "tabler:brand-google",
    callToAction: {
      target: "_blank",
      href: "https://www.credly.com/badges/e9d8b43d-5d2c-4cf6-baf3-4c4c279c5a7c/linked_in_profile",
    },
  },
  {
    title: "Cloud Digital Leader",
    description: "Google",
    icon: "tabler:brand-google",
    callToAction: {
      target: "_blank",
      href: "https://www.credly.com/badges/6dc9b9e4-3978-406c-a4c5-e744cd86e856/linked_in_profile",
    },
  },
  {
    title: "AWS Cloud Practitioner",
    description: "Amazon Web Services",
    icon: "tabler:brand-aws",
    callToAction: {
      target: "_blank",
      href: "https://www.credly.com/badges/4a519ed4-8888-49e4-a7a1-058f13a64740?source=linked_in_profile",
    },
  },
  {
    title: "Certified Kafka Developer",
    description: "Confluent",
    icon: "tabler:certificate",
    callToAction: {
      target: "_blank",
      href: "https://certificates.confluent.io/8dc5c4c1-5ddd-4eac-92be-f3ac3590d8f3#acc.ezJSkV4u",
    },
  },
  {
    title: "FinOps Certified Practitioner",
    description: "FinOps Foundation",
    icon: "tabler:cloud",
    callToAction: {
      target: "_blank",
      href: "https://verify.skilljar.com/c/vsocc7tfufs6",
    },
  },
  {
    title: "Certified Jenkins Engineer",
    description: "CloudBees",
    icon: "tabler:settings",
    callToAction: {
      target: "_blank",
      href: "https://certificates.cloudbees.com/cf0e1366-e4cb-44eb-ae9b-70730847a6db#acc.fxT16jRi",
    },
  },
];
---

<Layout metadata={metadata}>
  <!-- Custom Hero Section -->
  <section class="relative md:-mt-[76px] not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
      <div class="pt-12 md:pt-20 pb-0 md:pb-4">
        <div class="text-center pb-8 md:pb-16 max-w-5xl mx-auto">
          <h1
            class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            So, who the heck is <span class="text-accent">this guy?</span>
          </h1>
          <div
            class="max-w-3xl mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            <p class="text-xl text-muted mb-6 dark:text-slate-200">
              Principal Engineer <a
                href="https://www.sngular.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:underline text-accent font-bold">@Sngular</a
              >
            </p>
          </div>
        </div>
        <div
          class="max-w-7xl mx-auto px-0 sm:px-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
        >
          <Image
            src="~/assets/images/header-about.png"
            class="mx-auto rounded-md w-full shadow-lg"
            widths={[400, 768, 1024, 2040]}
            sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
            loading="eager"
            width={2040}
            alt="Alejandro Pena Lorenzo at the Grand Canyon"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About Content Section -->
  <WidgetWrapper>
    <div class="max-w-4xl mx-auto px-4">
      <div
        class="text-center mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <h3
          class="text-2xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4 font-heading"
        >
          👋 Hi there! I'm Alex
        </h3>
      </div>
      <div
        class="text-lg prose prose-lg dark:prose-invert max-w-none text-justify intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <p class="mb-4">
          I'm a <strong>Principal Engineer</strong> at <a
            class="text-blue-600 dark:text-blue-400 underline"
            href="https://sngular.com"
            target="_blank"
            rel="noopener noreferrer">Sngular</a
          >, based in Galicia ❤️ (Spain). Currently, I head the engineering and
          platform architecture for a joint venture product on GCP. Previously,
          I served as the <strong
            >Backend and Quality Engineering Chapter Lead</strong
          >, supporting engineering teams, driving business development, and
          shaping technical proposals across the organization.
        </p>
        <p class="mb-4">
          Before moving into this position, I spent several years leading
          engineering efforts for major US financial institutions. I've designed
          real-time stock exchange applications powered by <strong>Kafka</strong
          >, enhanced enterprise MFA login infrastructures, and guided massive
          organizations in adopting and scaling new quality practices.
        </p>
        <p class="mb-6">
          That enterprise experience deeply connected me with <strong
            >Contract Testing</strong
          >. I maintain an ongoing collaboration with SmartBear around their <a
            class="text-blue-600 dark:text-blue-400 underline"
            href="https://pactflow.io/"
            target="_blank"
            rel="noopener noreferrer">Swagger Contract Testing</a
          >
          product (formerly PactFlow). Much of the content you'll find on this site
          revolves around implementing these testing strategies effectively. Thanks
          for visiting!
        </p>
      </div>

      <div class="mt-12 max-w-3xl mx-auto">
        <ItemGrid
          items={socialLinks}
          columns={3}
          classes={{
            container: "gap-y-4 md:gap-y-8",
            panel:
              "max-w-none text-center flex flex-col items-center justify-center",
            title: "text-lg font-medium leading-6 dark:text-white mt-4",
            description: "text-muted dark:text-slate-400",
            icon: "mx-auto flex h-10 w-10 items-center justify-center rounded-full bg-green-600 dark:bg-green-700 text-gray-50 p-2",
            action: "mx-auto",
          }}
        />
      </div>
    </div>
  </WidgetWrapper>

  <!-- Work Experience Section -->
  <Steps
    id="resume"
    title="Work experience"
    items={[
      {
        title:
          'Principal Engineer — Product & Platform Architecture <br /> <span class="font-normal">Sngular · A Coruña, Spain</span> <br /> <span class="text-sm font-normal">2025 - Present</span>',
        description:
          "Head engineering for a joint venture product on GCP. Designing observability and platform capabilities for high-throughput distributed systems.",
        icon: "tabler:briefcase",
      },
      {
        title:
          'Principal Engineer — Chapter Lead Backend & QE <br /> <span class="font-normal">Sngular · A Coruña, Spain</span> <br /> <span class="text-sm font-normal">2024 - 2025</span>',
        description:
          "Led Backend & QE chapters across teams. Partnered with presales on technical solutions and defined career paths and training programs.",
        icon: "tabler:briefcase",
      },
      {
        title:
          'Head Engineer <br /> <span class="font-normal">Sngular US · Washington DC area</span> <br /> <span class="text-sm font-normal">2019 - 2024</span>',
        description:
          "Led engineering for major US financial clients (Freddie Mac, Capital One, PNC Bank). Implemented contract testing at enterprise scale, built cybersecurity MFA platforms, and developed real-time Kafka applications.",
        icon: "tabler:briefcase",
      },
      {
        title:
          'Earlier roles <br /> <span class="font-normal">8+ years in software engineering</span>',
        description:
          'Progressive experience from developer to tech lead across document management, workflow automation, and           enterprise applications. <a class="text-blue-600 dark:text-blue-400 underline" href="https://www.linkedin.com/in/alejandropenalorenzo/" target="_blank" rel="noopener noreferrer">See full history on LinkedIn</a>.',
        icon: "tabler:briefcase",
      },
    ]}
    classes={{ container: "max-w-3xl" }}
  />

  <!-- Education Section -->
  <Steps
    title="Education"
    items={[
      {
        title:
          'Bachelor\'s Degree in Computer Science <br /> <span class="font-normal">Universidade da Coruña, Spain</span> <br /> <span class="text-sm font-normal">2009</span>',
        icon: "tabler:school",
      },
      {
        title:
          'Associate\'s Degree in Telecommunications and Computer Systems <br /> <span class="font-normal">IES Urbano Lugrís, A Coruña, Spain</span> <br /> <span class="text-sm font-normal">2003</span>',
        icon: "tabler:school",
      },
    ]}
    classes={{ container: "max-w-3xl" }}
  />

  <!-- Certifications Section -->
  <WidgetWrapper>
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-8 md:mb-12">
        <h3
          class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4 font-heading"
        >
          Certifications
        </h3>
      </div>
      <div class="grid mx-auto gap-8 md:gap-y-12 lg:grid-cols-3 sm:grid-cols-2">
        {
          certifications.map(({ title, description, icon, callToAction }) => (
            <div class="intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <a
                href={callToAction?.href}
                target={callToAction?.target}
                rel="noopener noreferrer"
                aria-label={`${title} — ${description}, opens in new tab`}
                class="flex flex-col items-center text-center group"
              >
                <span class="mx-auto flex h-10 w-10 items-center justify-center rounded-full bg-blue-100 dark:bg-slate-800 text-primary dark:text-blue-300 p-2 group-hover:bg-blue-200 dark:group-hover:bg-slate-700 transition-colors">
                  <Icon name={icon} class="w-7 h-7" />
                </span>
                <h3 class="text-sm font-semibold leading-tight dark:text-white mt-4 group-hover:text-primary transition-colors">
                  {title}
                </h3>
                <p class="text-xs text-muted dark:text-slate-400 mt-1">
                  {description}
                </p>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </WidgetWrapper>
</Layout>
