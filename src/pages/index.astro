---
import Layout from "~/layouts/PageLayout.astro";
import Hero from "~/components/widgets/Hero.astro";
import Image from "~/components/common/Image.astro";
import BlogLatestPosts from "~/components/widgets/BlogLatestPosts.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";
import avatarImage from "~/assets/images/bio-photo.jpg";

const metadata = {
  title: "Alejandro Pena Lorenzo — Software Engineer",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    id="hero"
    actions={[
      {
        variant: "primary",
        text: "Read the blog",
        href: "/blog",
        icon: "tabler:book",
      },
      {
        text: "About me",
        href: "/about",
      },
    ]}
  >
    <Fragment slot="title">
      <Image
        src={avatarImage}
        alt="Alejandro Pena Lorenzo"
        class="w-24 h-24 rounded-full mx-auto mb-6 shadow-lg object-cover"
        width={96}
        height={96}
        loading="eager"
        decoding="async"
      />
      Hi there! I'm Alex 👋
    </Fragment>

    <Fragment slot="subtitle">
      16+ years building resilient platforms and leading cross-functional teams.
      Specialized in Backend, QE & DevOps - with a focus on Platform Engineering.
    </Fragment>
  </Hero>

  <!-- Latest Blog Posts ************* -->

  <BlogLatestPosts
    id="blog"
    title="Latest articles"
    information="Thoughts, reflections, and practical takeaways from engineering management and system design."
    layout="list"
    count={3}
    eagerCount={1}
  />

  <!-- Talks CTA ********************* -->

  <CallToAction
    actions={[
      {
        variant: "primary",
        text: "Watch the talks",
        href: "/talks",
        icon: "tabler:player-play",
      },
    ]}
  >
    <Fragment slot="title"> Live collaborations & talks </Fragment>

    <Fragment slot="subtitle">
      On stage and on screen: scaling teams, driving quality culture, and
      sharing what works (at least for me!)
    </Fragment>
  </CallToAction>
</Layout>
