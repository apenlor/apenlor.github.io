---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: "Software Engineer's Journal",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Read the blog',
        href: '/blog',
        icon: 'tabler:book',
      },
      {
        text: 'About me',
        href: '/about',
      },
    ]}
    image={{ src: '~/assets/images/bio-photo.jpg', alt: 'Alejandro Pena Lorenzo' }}
  >
    <Fragment slot="title">
      Hi, I'm <span class="text-accent dark:text-white">Alex</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Software Engineer</span> · Backend Chapter Lead at Sngular · Based in Galicia, Spain.
      <br />
      I write about backend development, quality engineering, DevOps, and contract testing.
    </Fragment>
  </Hero>

  <!-- Latest Blog Posts ************* -->

  <BlogLatestPosts
    title="Latest articles"
    information="Thoughts and insights on software engineering, contract testing, and building reliable systems."
  />

  <!-- Talks CTA ********************* -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Watch the talks',
        href: '/talks',
        icon: 'tabler:player-play',
      },
    ]}
  >
    <Fragment slot="title">
      Live collaborations & talks
    </Fragment>

    <Fragment slot="subtitle">
      Conference talks and live events on contract testing, API management, and software quality. Three recordings available — more to come.
    </Fragment>
  </CallToAction>
</Layout>
