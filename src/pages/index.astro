---
import Layout from "~/layouts/PageLayout.astro";
import Hero from "~/components/widgets/Hero.astro";
import BlogLatestPosts from "~/components/widgets/BlogLatestPosts.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";

const metadata = {
  title: "Alejandro Pena Lorenzo — Software Engineer",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    id="hero"
    title="Alejandro Pena Lorenzo"
    actions={[
      {
        variant: "primary",
        text: "Read the blog",
        href: "/blog",
        icon: "tabler:book",
      },
      {
        text: "About me",
        href: "/about",
      },
    ]}
  >
    <Fragment slot="subtitle">
      16+ years building resilient platforms and leading cross-functional teams.
      <br />
      Specialized in Backend systems, with focus on Quality Engineering, DevOps &
      Platform engineering.
    </Fragment>
  </Hero>

  <!-- Latest Blog Posts ************* -->

  <BlogLatestPosts
    id="blog"
    title="Latest articles"
    information="Thoughts and insights on software engineering, management, and scaling teams and technology."
    layout="list"
    count={3}
  />

  <!-- Talks CTA ********************* -->

  <CallToAction
    actions={[
      {
        variant: "primary",
        text: "Watch the talks",
        href: "/talks",
        icon: "tabler:player-play",
      },
    ]}
  >
    <Fragment slot="title"> Live collaborations & talks </Fragment>

    <Fragment slot="subtitle">
      Conference talks and live events on contract testing, API management, and
      software quality.
    </Fragment>
  </CallToAction>
</Layout>
